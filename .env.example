# Backend
APP_NAME=FlowOps
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=dev_secret_key_change_me_minimum_32_characters
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_USER=flowops_user
POSTGRES_PASSWORD=flowops_password
POSTGRES_DB=flowops_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://flowops_user:flowops_password@postgres:5432/flowops_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000